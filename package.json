{
  "name": "local-llm",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "concurrently --names server,angular --prefix-colors blue,green \"npm run server\" \"ng serve\"",
    "server": "node server/server.js",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "resetadmin": "node server/reset-admin.js"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.6",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.6",
    "@angular/platform-browser": "^21.2.6",
    "@angular/router": "^21.2.5",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "marked": "^17.0.5",
    "postcss": "^8.5.6",
    "rxjs": "~7.8.0",
    "selfsigned": "^5.5.0",
    "tailwindcss": "^3.4.11",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.6",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.1"
  },
  "overrides": {
    "undici": "^7.24.3"
  }
}
