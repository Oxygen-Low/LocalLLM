{
  "name": "local-llm",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "concurrently --names server,angular --prefix-colors blue,green \"npm run server\" \"ng serve --configuration lan\"",
    "start:no-lan": "concurrently --names server,angular --prefix-colors blue,green \"cross-env HOST=127.0.0.1 npm run server\" \"ng serve\"",
    "start:demo": "concurrently --names server,angular --prefix-colors blue,green \"cross-env DEMO_MODE=true npm run server\" \"ng serve --configuration lan\"",
    "server": "node server/server.js",
    "build": "ng build",
    "preview": "ng build --configuration preview && npx serve -s dist/local-llm/browser",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "resetadmin": "node server/reset-admin.js"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.8",
    "@angular/compiler": "^21.2.8",
    "@angular/core": "^21.2.8",
    "@angular/forms": "^21.2.8",
    "@angular/platform-browser": "^21.2.8",
    "@angular/router": "^21.2.8",
    "@dsnp/parquetjs": "^1.8.7",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "marked": "^18.0.0",
    "multer": "^2.1.1",
    "postcss": "^8.5.9",
    "rxjs": "~7.8.0",
    "tailwindcss": "^3.4.11",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.8",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.0.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "undici": "^7.24.3"
  }
}
