# Provider Configuration
# Users configure providers in user settings (per-user)
EnableOpenrouterProvider=true
EnableOpenAIProvider=true
EnableAnthropicProvider=true
EnableOpenAILikeAPIProvider=true

# OpenAI-Like API Provider Settings
OpenAILikeProviderName=ollama
OpenAILikeAPIKey=none
OpenAILikeAPIUrl=http://localhost:11434 # Local development default; use https:// for remote endpoints
OpenAILikeModelDefault=gemma3:1b # Default selected model
OpenAILikeModelDefault1=false # Optional extra model
OpenAILikeModelDefault2=false # Optional extra model
OpenAILikeModelDefault3=false # Optional extra model
